// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  EMPLOYEE
  MASY_OPS
  CLIENT
}

enum EmployeeStatus {
  ACTIVE
  ON_LEAVE
  OFFBOARDED
}

enum LeaveType {
  ANNUAL
  SICK
  OTHER
}

enum LeaveStatus {
  PENDING
  APPROVED
  DENIED
}

enum ReviewStatus {
  SUBMITTED
  MASY_REVIEWED
  RELEASED
}

enum ConcernVisibility {
  RAW
  MASY_REVIEWED
  CLIENT_VISIBLE
}

enum RoleStage {
  SOURCING
  INTERVIEWING
  OFFER
  FILLED
}

enum CandidateStage {
  SOURCING
  INTERVIEWING
  OFFER
  FILLED
  REJECTED
}

model ClientOrg {
  id                 String              @id @default(cuid())
  name               String
  status             String              @default("active")
  employees          Employee[]
  users              User[]
  openRoles          OpenRole[]
  monthlyReportNotes MonthlyReportNote[]
  createdAt          DateTime            @default(now())
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  role         Role
  clientOrgId  String?
  clientOrg    ClientOrg? @relation(fields: [clientOrgId], references: [id])
  employeeId   String?    @unique
  employee     Employee?  @relation(fields: [employeeId], references: [id])
  createdAt    DateTime   @default(now())
}

model Employee {
  id                 String              @id @default(cuid())
  clientOrgId        String
  clientOrg          ClientOrg           @relation(fields: [clientOrgId], references: [id])
  name               String
  roleTitle          String
  status             EmployeeStatus      @default(ACTIVE)
  startDate          DateTime
  email              String
  leaveBalanceDays   Int                 @default(20)
  user               User?
  attendanceRecords  AttendanceRecord[]
  leaveRequests      LeaveRequest[]
  performanceReviews PerformanceReview[]
  concerns           Concern[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model AttendanceRecord {
  id         String    @id @default(cuid())
  employeeId String
  employee   Employee  @relation(fields: [employeeId], references: [id])
  date       DateTime  @db.Date
  clockIn    DateTime
  clockOut   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([employeeId, date])
}

model LeaveRequest {
  id         String      @id @default(cuid())
  employeeId String
  employee   Employee    @relation(fields: [employeeId], references: [id])
  type       LeaveType
  startDate  DateTime    @db.Date
  endDate    DateTime    @db.Date
  reason     String?
  status     LeaveStatus @default(PENDING)
  approverId String?
  decidedAt  DateTime?
  createdAt  DateTime    @default(now())
}

model PerformanceReview {
  id             String       @id @default(cuid())
  employeeId     String
  employee       Employee     @relation(fields: [employeeId], references: [id])
  cycle          String
  selfAssessment String
  masyNotes      String?
  status         ReviewStatus @default(SUBMITTED)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Concern {
  id             String            @id @default(cuid())
  employeeId     String
  employee       Employee          @relation(fields: [employeeId], references: [id])
  content        String
  visibility     ConcernVisibility @default(RAW)
  curatedSummary String?
  escalated      Boolean           @default(false)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model OpenRole {
  id          String      @id @default(cuid())
  clientOrgId String
  clientOrg   ClientOrg   @relation(fields: [clientOrgId], references: [id])
  title       String
  stage       RoleStage   @default(SOURCING)
  candidates  Candidate[]
  createdAt   DateTime    @default(now())
}

model Candidate {
  id         String         @id @default(cuid())
  openRoleId String
  openRole   OpenRole       @relation(fields: [openRoleId], references: [id])
  name       String
  stage      CandidateStage @default(SOURCING)
  notes      String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model MonthlyReportNote {
  id          String    @id @default(cuid())
  clientOrgId String
  clientOrg   ClientOrg @relation(fields: [clientOrgId], references: [id])
  month       DateTime  @db.Date
  notes       String
  updatedAt   DateTime  @updatedAt

  @@unique([clientOrgId, month])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  targetType String
  targetId   String
  timestamp  DateTime @default(now())
}
